<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Flavor.Maui.Demo.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Flavor.Maui.Demo.Pages"
    Title="Flavor.Maui">

    <!-- Home — single content, no tab bar visible -->
    <ShellItem Route="Home" FlyoutItemIsVisible="False">
        <ShellContent ContentTemplate="{DataTemplate pages:HomePage}" />
    </ShellItem>

    <!-- Input section — contextual tabs -->
    <TabBar Route="InputSection" FlyoutItemIsVisible="False">
        <ShellContent Title="TextField" Icon="icon_text.png"
                      ContentTemplate="{DataTemplate pages:BasicPage}" Route="TextField" />
        <ShellContent Title="Validation" Icon="icon_check.png"
                      ContentTemplate="{DataTemplate pages:ValidationPage}" Route="Validation" />
        <ShellContent Title="Masks" Icon="icon_mask.png"
                      ContentTemplate="{DataTemplate pages:MasksPage}" Route="Masks" />
        <ShellContent Title="Styling" Icon="icon_palette.png"
                      ContentTemplate="{DataTemplate pages:StylingPage}" Route="Styling" />
    </TabBar>

    <!-- Button section — contextual tabs -->
    <TabBar Route="ButtonSection" FlyoutItemIsVisible="False">
        <ShellContent Title="Button" Icon="icon_check.png"
                      ContentTemplate="{DataTemplate pages:ButtonPage}" Route="Button" />
        <ShellContent Title="Icon Btn" Icon="icon_person.png"
                      ContentTemplate="{DataTemplate pages:IconButtonPage}" Route="IconBtn" />
        <ShellContent Title="FAB" Icon="icon_add.png"
                      ContentTemplate="{DataTemplate pages:FabPage}" Route="Fab" />
        <ShellContent Title="FAB Menu" Icon="icon_send.png"
                      ContentTemplate="{DataTemplate pages:FabMenuPage}" Route="FabMenu" />
    </TabBar>

</Shell>
